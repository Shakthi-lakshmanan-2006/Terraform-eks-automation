# =============================================
# Terraform .gitignore
# =============================================

# Local .terraform directory (provider binaries, modules cache - auto-generated)
.terraform/

# ⚠️  Terraform State Files — NEVER commit these!
# They may contain sensitive data like credentials, IP addresses, secrets.
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Terraform plan output files
*.tfplan
tfplan

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
# Exception: keep example var files
!*.tfvars.example
!*.tfvars.json.example

# Terraform crash log files
crash.log
crash.*.log

# Override files (used for local overrides, not meant to be shared)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# NOTE: .terraform.lock.hcl is intentionally tracked (NOT ignored)
# It ensures consistent provider versions across team members.

# =============================================
# OS / Editor specific
# =============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# VS Code
.vscode/
*.code-workspace

# IntelliJ / JetBrains
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# =============================================
# Environment / Credentials
# =============================================

# Environment variable files
.env
.env.*
!.env.example

# AWS credentials (never commit!)
.aws/
credentials

# SSH keys
*.pem
*.key
id_rsa
id_rsa.pub

# =============================================
# Logs & Temp files
# =============================================
*.log
*.tmp
*.temp
